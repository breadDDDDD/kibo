# ══════════════════════════════════════════════════════════════════════
#  SparePartAI — Environment Configuration
#  Copy to .env and fill in your values. Never commit .env to git.
# ══════════════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
LOG_LEVEL=INFO
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:8000","http://localhost:8080"]

# ── GCP ────────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ── Gemini ─────────────────────────────────────────────────────────────
# Leave EMPTY on GCP (Cloud Run) — ADC is used automatically.
# Set for local dev if not using gcloud auth application-default login.
GEMINI_API_KEY=

# Gemini model tuning
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=2048
GEMINI_TEMPERATURE=0.2

# ── Agent Search (Discovery Engine) ───────────────────────────────────
# GCP Console → Agent Builder → Apps → your app → ID in URL
AGENT_SEARCH_ENGINE_ID=your-search-app-id
AGENT_SEARCH_LOCATION=global

# ── Cloud SQL (PostgreSQL) ─────────────────────────────────────────────
# Format: project-id:region:instance-id
CLOUDSQL_INSTANCE_CONNECTION_NAME=your-project:asia-southeast1:sparepartai-db
CLOUDSQL_DB=sparepartdb
CLOUDSQL_USER=sparepart_user
CLOUDSQL_PASSWORD=your-db-password

# true  = local dev via Cloud SQL Auth Proxy (docker compose)
# false = Cloud Run via Unix socket (automatic)
CLOUDSQL_USE_PROXY=true
CLOUDSQL_PROXY_HOST=127.0.0.1
CLOUDSQL_PROXY_PORT=5432

DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Agent ──────────────────────────────────────────────────────────────
AGENT_MAX_TOOL_CALLS=10
RAG_TOP_K=5
